{
  "manifest_version": 3,
  "name": "Hyperscaled",
  "version": "1.0.6",
  "description": "Track your Hyperscaled account and Hyperliquid positions",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "notifications",
    "storage",
    "alarms",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "host_permissions": [
    "https://app.hyperliquid.xyz/trade/*",
    "https://api.hyperliquid.xyz/*",
    "https://app.hyperliquid-testnet.xyz/trade/*",
    "https://api.hyperliquid-testnet.xyz/*",
    "http://34.187.154.219:48888/*",
    "https://validator.mainnet.vantatrading.io/*",
    "https://*.vantatrading.io/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://app.hyperliquid.xyz/*", "https://app.hyperliquid-testnet.xyz/*"],
      "js": [
        "content/namespace.js",
        "content/state.js",
        "content/utils.js",
        "content/api.js",
        "content/toast.js",
        "content/banner.js",
        "content/pair-support.js",
        "content/clamping.js",
        "content/trade-gate.js",
        "content/mirror-preview.js",
        "content/input-binding.js",
        "content/payment.js",
        "content/navigation.js",
        "content/main.js"
      ],
      "css": ["content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://hyperscaled.trade/*", "https://*.hyperscaled.trade/*", "http://localhost/*"],
      "js": ["content-hyperscaled.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["images/hyperscaled-logo.svg", "icon16.png", "icon48.png", "icon128.png"],
      "matches": ["https://app.hyperliquid.xyz/*", "https://app.hyperliquid-testnet.xyz/*"]
    }
  ],
  "background": {
    "service_worker": "background/main.js",
    "type": "module"
  }
}
